# Gemfile for local preview of the folio-assistant docs site.
#
#   cd docs && bundle install && bundle exec jekyll serve
#
# CI does not use this file — it builds with the github-pages gem via
# actions/jekyll-build-pages (which whitelists jekyll-remote-theme).
source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.8"
gem "jekyll-remote-theme"
