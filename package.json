{
  "name": "@anthropic-ai/folio-assistant",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Content-agnostic assistant platform — MCP server, auth, UI, deploy. Pluggable content adapters for papers, guidelines, documentation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litlfred/qou.git",
    "directory": "folio-assistant"
  },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./types": "./src/types.ts",
    "./core/git": "./src/core/git.ts",
    "./core/feedback": "./src/core/feedback.ts",
    "./core/rbac": "./src/core/rbac.ts",
    "./core/cache": "./src/core/cache.ts",
    "./core/logging": "./src/core/logging.ts",
    "./blocks": "./src/blocks/index.ts",
    "./blocks/registry": "./src/blocks/registry.ts",
    "./blocks/types": "./src/blocks/types.ts",
    "./routes/branches": "./src/routes/branches.ts",
    "./routes/feedback": "./src/routes/feedback.ts",
    "./routes/chat": "./src/routes/chat.ts",
    "./tools/check-deps": "./src/tools/check-deps.ts",
    "./tools/preferences": "./src/tools/preferences.ts",
    "./tools/preview": "./src/tools/preview.ts"
  },
  "files": [
    "src/",
    "ui/",
    "viewer/sw-pyodide-cache.js",
    "viewer/register-sw.js",
    "folio.config.example.json",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "start:stdio": "bun run src/index.ts --stdio",
    "start:http": "bun run src/index.ts --http",
    "check-deps": "bun run src/index.ts --check-deps",
    "test:e2e": "playwright test",
    "test": "bun test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "@playwright/test": "^1.60.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "folio",
    "mcp",
    "assistant",
    "content-platform",
    "model-context-protocol"
  ]
}
