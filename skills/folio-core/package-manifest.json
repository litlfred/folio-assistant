    "labels": {
      "org.opencontainers.image.title": "folio-assistant-core",
      "org.opencontainers.image.description": "Content-agnostic platform agent skills (coordination, watchers, QA pipeline)",
      "org.opencontainers.image.source": "https://github.com/litlfred/folio-assistant"
