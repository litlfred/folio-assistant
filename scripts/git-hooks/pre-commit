#!/bin/sh
# Warn (and block) if lake-manifest.json is staged for commit.
# To intentionally commit it, use: git commit --no-verify

MANIFEST="content/quantum-observable-universe/lean/lake-manifest.json"

if git diff --cached --name-only | grep -qF "$MANIFEST"; then
    echo ""
    echo "⚠  $MANIFEST is staged for commit."
    echo ""
    echo "   This file is auto-generated by lake. If you intentionally"
    echo "   updated dependencies, re-run with:  git commit --no-verify"
    echo ""
    exit 1
fi
