{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["bun-types"],
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@content/*": ["../../content/*"],
      "@schemas/*": ["../../folio-assistant/schemas/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
