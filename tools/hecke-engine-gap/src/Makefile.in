# Makefile.in — generated from configure.ac via autoconf.
#
# Builds bin/<GAParch>/HeckeEngine.so — the GAP kernel module loaded
# via `LoadKernelExtension("HeckeEngine")` in ../init.g.

GAPROOT     = @GAPROOT@
GAParch     = @GAParch@
GAP_CFLAGS  = @GAP_CFLAGS@
GAP_LDFLAGS = @GAP_LDFLAGS@
GAP_LIBS    = @GAP_LIBS@

HECKE_C_INC = @HECKE_C_INC@
HECKE_C_LIB = @HECKE_C_LIB@

CC      = @CC@
CFLAGS  = -O2 -Wall -fPIC $(GAP_CFLAGS) -I$(HECKE_C_INC)
LDFLAGS = -shared $(GAP_LDFLAGS) \
          -L$(HECKE_C_LIB) -Wl,-rpath,$(HECKE_C_LIB)
LIBS    = $(GAP_LIBS) -lhecke_engine_c -lgmp -lmpfr

BIN_DIR = ../bin/$(GAParch)
TARGET  = $(BIN_DIR)/HeckeEngine.so

SOURCES = HeckeEngine.c
OBJECTS = $(SOURCES:.c=.o)

all: $(TARGET)

$(BIN_DIR):
	mkdir -p $(BIN_DIR)

$(TARGET): $(BIN_DIR) $(OBJECTS)
	$(CC) $(LDFLAGS) -o $@ $(OBJECTS) $(LIBS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJECTS) $(TARGET)

.PHONY: all clean
