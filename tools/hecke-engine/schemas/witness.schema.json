{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://folio.litlfred.org/schemas/hecke-engine/witness.schema.json",
  "title": "Computation witness",
  "description": "Output of folio-assistant/computations/witness_base.py::WitnessBuilder. Generalises the ComputationWitness interface in folio-assistant/schemas/types.ts.",
  "type": "object",
  "required": ["engine", "computedAt", "assertions", "allPassed"],
  "properties": {
    "engine": { "type": "string" },
    "engineVersion": { "type": "string" },
    "computedAt": { "type": "string", "format": "date-time" },
    "commitSha": { "type": "string" },
    "assertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/Assertion" }
    },
    "allPassed": { "type": "boolean" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "computation": { "type": "string" },
    "scriptFile": { "type": "string" },
    "scriptHash": { "type": "string" },
    "scriptCommitSha": { "type": "string" },
    "description": { "type": "string" },
    "contentBlock": { "type": "string" },
    "parameters": { "type": "object" },
    "data": { "type": "object" },
    "caveats": { "type": "array", "items": { "type": "string" } },
    "results": { "type": "array" }
  },
  "$defs": {
    "Assertion": {
      "type": "object",
      "required": ["name", "computed", "expected", "passed"],
      "properties": {
        "name": { "type": "string" },
        "computed": { "type": ["number", "string", "boolean", "array", "object", "null"] },
        "expected": { "type": ["number", "string", "boolean", "array", "object", "null"] },
        "passed": { "type": "boolean" },
        "tolerance": { "type": ["number", "null"] },
        "unit": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] }
      }
    }
  }
}
