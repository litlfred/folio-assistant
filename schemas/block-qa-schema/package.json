{
  "name": "@litlfred/block-qa-schema",
  "version": "0.1.0",
  "description": "Zod schemas + JSON Schema for the QOU block-QA sidecar format. Cross-language interchange schema for <block>.qa.json multi-reviewer audit reports and <criterion-id>.script.json checker-staleness sidecars.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litlfred/qou.git",
    "directory": "tools/block-qa-schema"
  },
  "homepage": "https://github.com/litlfred/qou/tree/main/tools/block-qa-schema",
  "bugs": "https://github.com/litlfred/qou/issues",
  "keywords": ["qa", "audit", "json-schema", "zod", "qou", "provenance", "staleness"],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "schema/block-qa.schema.json",
    "schema/qa-script.schema.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schema": "./schema/block-qa.schema.json",
    "./schema/qa-script": "./schema/qa-script.schema.json"
  },
  "scripts": {
    "build": "tsup js/index.ts --format cjs,esm --dts --out-dir dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "zod": "^3.22.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4",
    "zod": "^3.22.0"
  }
}
