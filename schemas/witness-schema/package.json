{
  "name": "@litlfred/witness-schema",
  "version": "0.1.1",
  "description": "Zod schemas + JSON Schema for the QOU witness JSON format. Cross-language interchange schema for *.witness.json files emitted by qou-substrate's WitnessBuilder.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litlfred/qou.git",
    "directory": "tools/witness-schema"
  },
  "homepage": "https://github.com/litlfred/qou/tree/main/tools/witness-schema",
  "bugs": "https://github.com/litlfred/qou/issues",
  "keywords": ["witness", "json-schema", "zod", "qou", "reproducibility"],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "schema/witness.schema.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schema": "./schema/witness.schema.json"
  },
  "scripts": {
    "build": "tsup js/index.ts --format cjs,esm --dts --out-dir dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "zod": "^3.22.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^1",
    "zod": "^3.22.0"
  }
}
